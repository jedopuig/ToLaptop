        <dc:title>The New Aggregated Distributed Energy Resources (der_a) Model for Transmission Planning Studies: 2019 Update</dc:title>
        <dc:identifier>
            <dcterms:URI>
                <rdf:value>https://www.epri.com/research/products/000000003002015320</rdf:value>

    <rdf:Description rdf:about="https://www.researchgate.net/publication/358285161_Modelling_of_Stationary_and_Dynamic_Demand_Behavior_Considering_Sectoral_and_Regional_Characteristics">
        <z:itemType>conferencePaper</z:itemType>
        <dcterms:isPartOf>
            <bib:Journal>
                <dc:title>ResearchGate</dc:title>
                <dc:identifier>DOI 10.34890/474</dc:identifier>
